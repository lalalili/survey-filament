{
    "name": "lalalili/survey-filament",
    "description": "Filament admin UI layer for the survey-core package.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "lalalili/survey-core": "^0.1.1",
        "filament/filament": "^4.0|^5.0",
        "filament/forms": "^4.0|^5.0",
        "filament/schemas": "^4.0|^5.0",
        "filament/tables": "^4.0|^5.0",
        "filament/actions": "^4.0|^5.0",
        "filament/widgets": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "lalalili/marketing-automation": "^0.1.1",
        "phpstan/phpstan": "~2.2.0",
        "lalalili/package-testing-support": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../audience-core",
            "options": {
                "symlink": true,
                "versions": {
                    "lalalili/audience-core": "0.1.1"
                }
            }
        },
        {
            "type": "path",
            "url": "../email-campaign",
            "options": {
                "symlink": true,
                "versions": {
                    "lalalili/email-campaign": "0.1.1"
                }
            }
        },
        {
            "type": "path",
            "url": "../marketing-automation",
            "options": {
                "symlink": true,
                "versions": {
                    "lalalili/marketing-automation": "0.1.1"
                }
            }
        },
        {
            "type": "path",
            "url": "../survey-core",
            "options": {
                "symlink": true,
                "versions": {
                    "lalalili/survey-core": "0.1.1"
                }
            }
        },
        {
            "type": "path",
            "url": "../package-testing-support",
            "options": {
                "symlink": false
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Lalalili\\SurveyFilament\\": "src/"
        }
    },
    "autoload-dev": {
        "files": [
            "stubs/google-client-stub.php"
        ],
        "psr-4": {
            "Lalalili\\SurveyFilament\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lalalili\\SurveyFilament\\SurveyFilamentServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --configuration=phpstan.neon.dist --no-progress",
        "format": "pint"
    }
}
